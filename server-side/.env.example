# ========================================
# Database Configuration (PostgreSQL)
# ========================================
DATABASE_URL=postgresql://lms_user:secure_password@localhost:5432/lms_db
DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=lms_db
DB_USERNAME=lms_user
DB_PASSWORD=secure_password

# ========================================
# Server Configuration
# ========================================
PORT=3000
NODE_ENV=development

# ========================================
# JWT Configuration (CHANGE THESE IN PRODUCTION!)
# ========================================
# Generate secure keys using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# ========================================
# Redis Configuration
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========================================
# Email Configuration (SMTP)
# ========================================
# Using Gmail? Generate App Password: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@kitalearn.com

# ========================================
# AWS S3 Configuration (Optional)
# ========================================
# For file uploads (certificates, course materials, etc.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=kitalearn-lms

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ========================================
# CORS Configuration
# ========================================
# Frontend URL
CORS_ORIGIN=http://localhost:3001

# ========================================
# API Documentation
# ========================================
API_VERSION=v1
API_PREFIX=/api/v1

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# Session Configuration
# ========================================
SESSION_TIMEOUT=3600000
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=900000

# ========================================
# File Upload Configuration
# ========================================
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,ppt,pptx,xls,xlsx,jpg,jpeg,png,mp4,mov

# ========================================
# Exam Configuration
# ========================================
EXAM_TIMEOUT_MINUTES=120
MAX_EXAM_ATTEMPTS=3
AUTO_GRADE_PERCENTAGE=95

# ========================================
# Certificate Configuration
# ========================================
CERTIFICATE_VALIDITY_YEARS=5
PASSING_SCORE=60
