        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse the JSON response",
                  "const response = pm.response.json();",
                  "",
                  "// 2. Check if the login was successful",
                  "if (response.success === true) {",
                  "    // 3. Save to Collection Variables",
                  "    // Using the exact keys from your JSON: data.access_token and data.refresh_token",
                  "    pm.collectionVariables.set('auth_token', response.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', response.data.refresh_token);",
                  "    pm.collectionVariables.set('user_id', response.data.user.id);",
                  "    console.log('✅ Admin login successful - tokens updated!');",
                  "} else {",
                  "    console.error('❌ Login failed: ' + (response.message || 'Unknown error'));",
                  "}"
