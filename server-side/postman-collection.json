              "raw": "{\n  \"email\": \"newuser@lms.test\",\n  \"password\": \"password123456\",\n  \"full_name\": \"New Student User\",\n  \"phone_number\": \"+1-555-555-5555\",\n  \"role\": \"student\"\n}"
